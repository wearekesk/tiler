# Copy to `.env`. Kesk Maps Server has two endpoints:
#   /staticmap  — composed static map images (uses PMTILES_URL)
#   /tiles/...  — raw PMTiles tiles + TileJSON (uses PMTILES_PATH)

# The source for /staticmap. A local file path or an http(s):// URL. This can be
# a world/planet archive or a regional extract.
PMTILES_URL=https://protomaps.github.io/PMTiles/protomaps(vector)ODbL_firenze.pmtiles

# The archive-name template for /tiles/{name}/z/x/y.ext. `{name}` is substituted
# from the request path (default `{name}.pmtiles`). Point at a directory of
# archives or a bucket URL. Traversal (`..`) in names is rejected.
# PMTILES_PATH=/data/{name}.pmtiles

# Optional: port to listen on (defaults to 3000).
# PORT=3000

# Optional: log/trace filter (default "info"), e.g. info,tiler=debug
# RUST_LOG=info

# Optional: export spans to an OpenTelemetry collector over OTLP/gRPC.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Optional: CORS. Comma-separated allowed origins, or `*` / unset for any.
# ALLOWED_ORIGINS=https://example.com,https://maps.example.com

# Optional: Cache-Control for /tiles responses (default "public, max-age=86400").
# TILES_CACHE_CONTROL=public, max-age=86400

# Optional: hostname used in the TileJSON `tiles` URLs (default: request Host).
# PUBLIC_HOSTNAME=maps.example.com
