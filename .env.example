# Copy to `.env` and fill in a default PMTiles source, so requests can omit
# the `pmtiles` query parameter. Either a local file path or an http(s):// URL.
PMTILES_URL=https://protomaps.github.io/PMTiles/protomaps(vector)ODbL_firenze.pmtiles

# Optional: port to listen on (defaults to 3000).
# PORT=3000

# Optional: log/trace filter (default "info"), e.g. info,tiler=debug
# RUST_LOG=info

# Optional: export spans to an OpenTelemetry collector over OTLP/gRPC.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
